# Copy this file to .env and keep .env local.
# Never commit real Slack, OpenAI, AI-VERDE, GitHub, or Tavily tokens.
# Rotate tokens immediately if they are exposed in git, screenshots, logs, or chat.

# --- ScienceClaw runtime ----------------------------------------------------
DATA_ROOT=/data
DATA_DIR=./data
OPENCLAW_STATE_DIR=~/.openclaw
SCIENCECLAW_CONTAINER_NAME=openclaw-local
WORKSPACE_DIR=./workspace
WORKSPACE_UI_PORT=8888
WORKSPACE_UI_TOKEN=scienceclaw
EXTERNAL_STORAGE_DIR=./external_storage
SCIENCECLAW_RUNTIME_SECRETS_DIR=./secrets
SCIENCECLAW_CMS_PORT=8090
SCIENCECLAW_CONTAINER_CPUS=2.0
SCIENCECLAW_CONTAINER_MEMORY=50g
SCIENCECLAW_BRANDING=1
SCIENCECLAW_PROJECT_TITLE=OASIS Scientific Discussion Panel
SCIENCECLAW_WORKER_IMAGE=scienceclaw-spatiotemporal-worker:local
SCIENCECLAW_WORKER_CPUS=2
SCIENCECLAW_WORKER_MEMORY=4g
SCIENCECLAW_K8S_NAMESPACE=scienceclaw

# --- OpenClaw gateway and model routing ------------------------------------
OPENCLAW_MODEL=verde/js2/gpt-oss-120b
OPENCLAW_DEFAULT_MODEL=verde/js2/gpt-oss-120b
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_AUTH_MODE=token
# Optional local browser token. If set, open:
# http://127.0.0.1:${OPENCLAW_GATEWAY_PORT}/#token=<this-value>
OPENCLAW_GATEWAY_TOKEN=
# Optional local browser password. If OPENCLAW_GATEWAY_AUTH_MODE=password,
# enter this value in the Control UI password field.
OPENCLAW_GATEWAY_PASSWORD=
OPENCLAW_VISIBLE_REPLIES_MODE=message_tool
OPENCLAW_VERDE_MINIMAL_TOOLS=0
OPENCLAW_EXEC_POLICY_PRESET=cautious
# Keep the default agent model allowlist Verde-only, even when a persisted
# OpenClaw state volume contains older OpenAI/Codex routes. Set to 0 only when
# intentionally testing multiple model providers.
SCIENCECLAW_VERDE_ONLY_MODE=1
# Disable the extra one-time Control UI browser/device approval gate for local
# laptop runs. Token or password auth still applies. Set to 0 to require pairing.
SCIENCECLAW_DISABLE_CONTROL_UI_DEVICE_PAIRING=1
# Disable persisted OpenClaw cron jobs on container startup. Set to 0 only when
# intentionally testing scheduled Gateway work.
SCIENCECLAW_DISABLE_OPENCLAW_CRON=1

# Optional: only needed when using OpenAI API-key mode instead of ChatGPT/Codex OAuth.
OPENAI_API_KEY=

# --- Scientific discussion panel controls ----------------------------------
# Defaults are conservative: no autonomous recurring panel loop is started
# unless PANEL_AUTORUN is explicitly enabled by the operator.
PANEL_AUTORUN=0
PANEL_DISCUSSION_INTERVAL_MINUTES=60
PANEL_MAX_TURNS_PER_ROUND=12
PANEL_MAX_PANELISTS_PER_ROUND=4
PANEL_MAX_RESEARCH_TASKS_PER_ROUND=2
PANEL_MAX_EXPERIMENTS_PER_DAY=1
PANEL_REQUIRE_EXPERIMENT_APPROVAL=1
PANEL_DAILY_TOKEN_BUDGET=
PANEL_DAILY_COMPUTE_BUDGET_MINUTES=
PANEL_AUTO_SUMMARY_INTERVAL_ROUNDS=4
PANEL_REPETITION_THRESHOLD=0.82
PANEL_IDLE_WHEN_NO_TOPIC=1
PANEL_TIMEZONE=America/Denver
PANEL_DEFAULT_STATUS=paused
PANEL_ALLOW_WEB_RESEARCH=0
PANEL_ALLOW_AUTO_EXPERIMENTS=0

# --- Slack Interaction Agent ------------------------------------------------
SLACK_BOT_TOKEN=xoxb-your-token
# Socket Mode app-level token. Create under Slack app settings > Basic Information > App-Level Tokens.
# It must start with xapp- and have the connections:write scope.
# Do not use the Slack signing secret or legacy verification token here.
SLACK_APP_TOKEN=xapp-1-APPID-INSTALLID-your-token
SLACK_DEFAULT_CHANNEL=#science-discussion-panel

# --- AI-VERDE open-model experiments ---------------------------------------
# Keep real values local, and do not commit provider keys or endpoint secrets.
# Docs: https://aiverde-docs.cyverse.ai/api/
VERDE_LLM_BASE_URL=https://llm-api.cyverse.ai/v1
VERDE_LLM_API_KEY=
# Optional mounted secret-file path. If set, the runtime should read the key
# from this file and must not print the file contents.
VERDE_LLM_API_KEY_FILE=
# Default Verde model used by the local panel route.
VERDE_LLM_DEFAULT_MODEL=js2/gpt-oss-120b
VERDE_LLM_PROVIDER_NAME=verde

# --- Optional external services -------------------------------------------
# GitHub Repository Manager and agent repo access.
# Prefer fine-grained, repository-scoped tokens for the target organization/repos.
# Do not commit real tokens. For Docker/Kubernetes secrets, set GITHUB_TOKEN_FILE
# to a mounted secret path such as /run/secrets/github_token instead of GITHUB_TOKEN.
# In GitHub Actions or Codespaces, store the value in GitHub Secrets and materialize
# it only into a runner-local secret file before starting Docker.
GITHUB_TOKEN=
GITHUB_TOKEN_FILE=
SCIENCECLAW_CONFIGURE_GITHUB=1
TAVILY_API_KEY=

# --- Optional external storage providers -----------------------------------
# Keep real credentials local. The default demo paths do not require secrets.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
S3_ENDPOINT_URL=
WEBDAV_USER=
WEBDAV_PASSWORD=
IRODS_HOST=
IRODS_PORT=
IRODS_ZONE=
IRODS_USER_NAME=
IRODS_PASSWORD=
IRODS_DEFAULT_RESOURCE=
